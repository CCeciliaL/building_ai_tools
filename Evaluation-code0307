onse = openai_client.embeddings.create(\n","            input=txt[:10000],\n","            model=EMBED_MODEL\n","        )\n","        embeddings.append(response.data[0].embedding)\n","    return embeddings\n","\n","print(f\"Found group folder: {GROUP_FOLDER}\")\n","print(f\"Connected to '{COLLECTION}' — {collection.count()} chunks ready.\")\n","print(\"You can now run the query cells directly.\")"]},{"cell_type":"code","execution_count":null,"id":"m3n4o5p6","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":4,"status":"ok","timestamp":1772902817806,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"m3n4o5p6","outputId":"137ce0fe-9d99-441d-9a7c-245b5929801f"},"outputs":[{"output_type":"stream","name":"stdout","text":["query_rag() and display_results() are ready.\n"]}],"source":["import json\n","\n","SYSTEM_PROMPT = \"\"\"You are an expert climate risk and sustainability analyst specialising in G-SIB bank disclosures.\n","\n","Analyse the provided excerpts and return a JSON object with EXACTLY this structure:\n","{\n","  \"summary\": \"<2-3 sentence overview of findings across all banks>\",\n","  \"findings\": [\n","    {\n","      \"bank\": \"<bank name>\",\n","      \"source\": \"<filename>\",\n","      \"risk_type\": \"<one of: Transition Risk | Physical Risk | Both>\",\n","      \"sdgs\": [\"<e.g. SDG 13: Climate Action>\", ...],\n","      \"key_points\": [\"<specific finding 1>\", \"<specific finding 2>\", ...]\n","    }\n","  ],\n","  \"cross_firm_comparison\": \"<paragraph comparing how banks differ in their approach>\",\n","  \"sdgs_identified\": [\"<all unique SDGs mentioned across all banks>\"]\n","}\n","\n","Classification rules:\n","- Transition Risk: policy changes, carbon pricing, regulation, technology shifts, stranded assets, legal risk\n","- Physical Risk: flooding, heat, sea-level rise, extreme weather, asset damage, supply chain disruption\n","- Both: if the excerpt covers both categories\n","\n","SDG rules — only tag SDGs that are explicitly mentioned or clearly implied:\n","- SDG 7: Affordable and Clean Energy\n","- SDG 8: Decent Work and Economic Growth\n","- SDG 9: Industry, Innovation and Infrastructure\n","- SDG 11: Sustainable Cities and Communities\n","- SDG 12: Responsible Consumption and Production\n","- SDG 13: Climate Action\n","- SDG 14: Life Below Water\n","- SDG 15: Life on Land\n","- SDG 17: Partnerships for the Goals\n","\n","Return ONLY valid JSON — no markdown, no explanation outside the JSON.\"\"\"\n","\n","\n","def query_rag(user_query, n_results=5, bank_filter=None):\n","    \"\"\"\n","    Run a structured RAG query against the bank sustainability corpus.\n","\n","    Parameters\n","    ----------\n","    user_query  : str  — natural language question\n","    n_results   : int  — number of chunks to retrieve\n","    bank_filter : str  — restrict to a specific bank, e.g. 'JPMorgan Chase'\n","    \"\"\"\n","    # Step 1: embed query\n","    query_embedding = get_embeddings([user_query])\n","\n","    # Step 2: retrieve from ChromaDB\n","    where = {'bank': bank_filter} if bank_filter else None\n","    results = collection.query(\n","        query_embeddings = query_embedding,\n","        n_results        = n_results,\n","        where            = where,\n","        include          = ['documents', 'metadatas'],\n","    )\n","\n","    docs  = results['documents'][0]\n","    metas = results['metadatas'][0]\n","\n","    # Step 3: build labelled context\n","    context_parts = []\n","    for doc, meta in zip(docs, metas):\n","        context_parts.append(f\"[{meta['bank']} — {meta['filename']}]\\n{doc}\")\n","    context = '\\n\\n---\\n\\n'.join(context_parts)\n","\n","    prompt = f\"\"\"Analyse the following excerpts and answer the question using the required JSON format.\n","\n","## EXCERPTS\n","{context}\n","\n","## QUESTION\n","{user_query}\"\"\"\n","\n","    # Step 4: call LLM with JSON mode enforced\n","    response = openai_client.chat.completions.create(\n","        model           = LLM_MODEL,\n","        response_format = {\"type\": \"json_object\"},\n","        messages        = [\n","            {'role': 'system', 'content': SYSTEM_PROMPT},\n","            {'role': 'user',   'content': prompt},\n","        ],\n","    )\n","\n","    raw = response.choices[0].message.content\n","    data = json.loads(raw)\n","    return data\n","\n","\n","def display_results(data):\n","    \"\"\"Pretty-print the structured JSON output as a readable report.\"\"\"\n","    print(\"=\" * 70)\n","    print(\"SUMMARY\")\n","    print(\"=\" * 70)\n","    print(data.get(\"summary\", \"\"))\n","\n","    print(\"\\n\" + \"=\" * 70)\n","    print(\"FINDINGS BY BANK\")\n","    print(\"=\" * 70)\n","    for f in data.get(\"findings\", []):\n","        print(f\"\\n🏦 {f['bank']}  |  Risk Type: {f['risk_type']}\")\n","        print(f\"   Source: {f['source']}\")\n","        sdgs = ', '.join(f.get('sdgs', [])) or 'None identified'\n","        print(f\"   SDGs:   {sdgs}\")\n","        print(\"   Key Points:\")\n","        for point in f.get('key_points', []):\n","            print(f\"     • {point}\")\n","\n","    print(\"\\n\" + \"=\" * 70)\n","    print(\"CROSS-FIRM COMPARISON\")\n","    print(\"=\" * 70)\n","    print(data.get(\"cross_firm_comparison\", \"\"))\n","\n","    print(\"\\n\" + \"=\" * 70)\n","    print(\"ALL SDGs IDENTIFIED ACROSS BANKS\")\n","    print(\"=\" * 70)\n","    all_sdgs = data.get(\"sdgs_identified\", [])\n","    print(', '.join(all_sdgs) if all_sdgs else \"None identified\")\n","    print(\"=\" * 70)\n","\n","\n","print(\"query_rag() and display_results() are ready.\")"]},{"cell_type":"markdown","id":"n4o5p6q7","metadata":{"id":"n4o5p6q7"},"source":["## 7. Example Queries"]},{"cell_type":"code","execution_count":null,"id":"o5p6q7r8","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":8827,"status":"ok","timestamp":1772902830608,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"o5p6q7r8","outputId":"6edcd8bf-a025-41e0-af0e-c7431b0be9d7"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","Both Bank of America and HSBC identify transition and physical risks as significant climate-related risks, implementing tiered risk management frameworks to address them. Bank of America emphasizes measures such as scenario analysis and monitoring insurance risks, while HSBC focuses on continuous enhancement of climate risk capabilities and industry alignment.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: SustainabilityatBofA2025_WCAG2.2_121625.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Bank of America developed a Climate Risk Framework to identify, measure, monitor, and control climate risks.\n","     • They assess potential physical and transition risks that could impact asset valuations and employ stress tests to analyze impacts.\n","     • They manage credit risk through strong underwriting practices, monitoring economic conditions, and improving physical risk modeling.\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: Sustainability_at_Bank_of_America_2024_Report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • BofA identifies physical and transition risks across its lines of business and control functions.\n","     • They enhanced their risk identification process to incorporate climate-related factors and expanded their risk identification capabilities.\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250327-annual-report-and-accounts-2024-en.pdf\n","   SDGs:   SDG 13: Climate Action, SDG 17: Partnerships for the Goals\n","   Key Points:\n","     • HSBC's approach includes enhancing climate risk capabilities and regular review to incorporate maturing frameworks and tools.\n","     • The bank conducts annual climate risk materiality assessments impacting both financial and non-financial risk types.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","Bank of America focuses on a detailed framework for identifying and managing both physical and transition risks with specific attention to credit and market risks through tools like stress testing and insurance oversight. They enhance risk identification by embedding climate factors into their processes. HSBC, on the other hand, centers its efforts on continually enhancing their climate risk management capabilities across the business, aligning with regulatory expectations and industry practices. HSBC adopts an iterative process that includes annual materiality assessments to gauge climate risks over different time horizons.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action, SDG 17: Partnerships for the Goals\n","======================================================================\n"]}],"source":["# Query 1 — transition risk across all banks\n","data = query_rag(\n","    'How do major banks describe their transition risks related to climate change? '\n","    'What specific measures are they taking?',\n","    n_results=5\n",")\n","display_results(data)"]},{"cell_type":"code","execution_count":null,"id":"p6q7r8s9","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":8927,"status":"ok","timestamp":1772902839537,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"p6q7r8s9","outputId":"03a53af1-1df3-4185-e636-6949f2a4a762"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","The disclosed reports from various banks reveal substantial financial commitments toward sustainable development goals (SDGs), focusing largely on transition to low-carbon economies, climate action, and socioeconomic development. Banks vary in their approaches, with diverse targets and strategies outlined for achieving net-zero emissions and supporting the United Nations SDGs.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 Bank of America  |  Risk Type: Transition Risk\n","   Source: Sustainability_at_Bank_of_America_2024_Report.pdf\n","   SDGs:   SDG 7: Affordable and Clean Energy, SDG 11: Sustainable Cities and Communities, SDG 13: Climate Action, SDG 12: Responsible Consumption and Production\n","   Key Points:\n","     • Mobilized $560 billion toward sustainable finance, with $316 billion for environmental transition.\n","     • Created an internal taxonomy aligned with the 17 UN SDGs to guide sustainable finance activities.\n","\n","🏦 JPMorgan Chase  |  Risk Type: Both\n","   Source: jpmc-esg-report-2023.pdf\n","   SDGs:   SDG 13: Climate Action, SDG 8: Decent Work and Economic Growth, SDG 9: Industry, Innovation and Infrastructure\n","   Key Points:\n","     • Established a $2.5 trillion sustainable development target to be achieved by 2030, facilitating transitions to a low-carbon economy.\n","     • Incorporated SDGs into their sustainable development target methodology.\n","\n","🏦 Unknown  |  Risk Type: Transition Risk\n","   Source: accelerating-transition-report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Outlined interim targets aligning with a net-zero by 2050 pathway.\n","     • Emphasized the role of supportive public policy and technological advancement in climate action.\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action, SDG 9: Industry, Innovation and Infrastructure\n","   Key Points:\n","     • Aims to provide and facilitate $750 billion to $1 trillion in sustainable finance by 2030.\n","     • Updated its Green Financing Framework to align with sustainability strategy.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","While all banks are committed to supporting the UN SDGs, Bank of America and JPMorgan Chase have specific financial targets aimed at facilitating transition to a low-carbon economy, emphasizing different aspects such as energy efficiency and sustainable growth. HSBC focuses on both green bonds and broad climate risk management, integrating targets across their operations. All firms actively align their strategies with the SDG framework; however, their methodologies and interpretations of SDGs largely depend on financial products and services offered.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 7: Affordable and Clean Energy, SDG 11: Sustainable Cities and Communities, SDG 13: Climate Action, SDG 12: Responsible Consumption and Production, SDG 8: Decent Work and Economic Growth, SDG 9: Industry, Innovation and Infrastructure\n","======================================================================\n"]}],"source":["# Query 2 — SDG commitments\n","data = query_rag(\n","    'Which SDGs do these banks claim to support, and how do they link '\n","    'their climate commitments to specific SDG targets?',\n","    n_results=6\n",")\n","display_results(data)"]},{"cell_type":"code","execution_count":null,"id":"q7r8s9t0","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":7635,"status":"ok","timestamp":1772902847174,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"q7r8s9t0","outputId":"349f043c-f0fe-4c91-a92c-d33578da2e43"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","JPMorgan Chase's disclosures highlight their comprehensive engagement in supporting a low-carbon transition through sector-specific net-zero targets. The bank's efforts include setting material financial targets, aligning their strategies with science-based scenarios, and engaging with clients for decarbonization. However, the bank acknowledges challenges such as market conditions and technological developments that could impact the attainment of these targets.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 JPMorgan Chase  |  Risk Type: Both\n","   Source: jpmc-esg-report-2023.pdf\n","   SDGs:   SDG 7: Affordable and Clean Energy, SDG 13: Climate Action\n","   Key Points:\n","     • JPMorgan Chase is working to align key sectors, including Oil & Gas, Electric Power, Auto Manufacturing, with net zero emissions by 2050.\n","     • The bank disclosed financed emissions for Oil & Gas, emphasizing decarbonization and opportunity in methane emissions reduction.\n","\n","🏦 JPMorgan Chase  |  Risk Type: Transition Risk\n","   Source: jpmc-sustainability-report-2024 copy.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Progress on net-zero targets is challenged by factors like global decarbonization pace and energy demand from data centers.\n","     • The bank outlines its financing approach across carbon intense sectors, highlighting financing trends and targets alignment with science-based scenarios.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","JPMorgan Chase focuses heavily on setting science-based, sector-specific net zero targets and disclosing financed emissions. Their engagement is directed more towards assisting clients in their decarbonization efforts within a well-structured framework, compared to peers who might prioritize direct investment in zero-carbon alternatives or focus on reducing physical risks such as extreme weather impacts.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 7: Affordable and Clean Energy, SDG 13: Climate Action\n","======================================================================\n"]}],"source":["# Query 3 — bank-specific\n","data = query_rag(\n","    'What are the key net-zero targets and climate commitments?',\n","    n_results=8,\n","    bank_filter='JPMorgan Chase'\n",")\n","display_results(data)"]},{"cell_type":"code","execution_count":null,"id":"r8s9t0u1","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"executionInfo":{"elapsed":9362,"status":"ok","timestamp":1772902856533,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"r8s9t0u1","outputId":"4f24331c-94b6-420e-ad5d-3642fd75433e"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","Bank of America and UBS both acknowledge the significance of climate risks and detail their management strategies. They identify various types of physical risks in their disclosures, emphasizing their methods for monitoring and mitigation. While Bank of America covers a broad spectrum of both physical and transition risks, UBS mainly focuses on physical risks, underscoring its model for gauging these risks globally.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: Sustainability_at_Bank_of_America_2024_Report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Bank of America identifies both acute and chronic physical risks, including extreme weather events like hurricanes and floods.\n","     • They include climate-related policy, legal, technology, and market changes in transition risks.\n","     • Their risk management framework incorporates roles from front line units to corporate audit, providing comprehensive risk identification and management.\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: SustainabilityatBofA2025_WCAG2.2_121625.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Detailed climate risk framework includes monitoring of physical risks like floods, hurricanes, and asset-level vulnerabilities.\n","     • Transition risks account for the bank's strategic planning towards a low-carbon economy.\n","     • Key risk types include credit and market risks affected by climate events and the transition to sustainable practices.\n","\n","🏦 UBS  |  Risk Type: Physical Risk\n","   Source: annual-report-ubs-group-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • UBS developed a physical risk rating model (PR RM) to measure risks from four acute physical hazards: wildfires, heatwaves, floods, and tropical cyclones.\n","     • Their physical risk management model considers geographic exposure with an adaptive capacity context.\n","     • The exposure to physical risks has decreased due to strategic reductions in sensitive sectors, emphasizing a proactive stance on risk management.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","When comparing Bank of America and UBS, both banks take climate risks seriously, with Bank of America focusing on an integrated approach to manage both physical and transition risks through a comprehensive risk management framework. UBS, on the other hand, concentrates more specifically on measuring and managing physical risks using a tailored risk rating model, highlighting acute hazards and geographic contextual understanding. While Bank of America covers broader scenarios and implications of climate change across its operations, UBS primarily emphasizes reducing exposure through strategic planning.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action\n","======================================================================\n"]}],"source":["# Query 4 — cross-bank physical risk comparison\n","data = query_rag(\n","    'Compare how different banks assess and disclose physical climate risks. '\n","    'What categories of physical risk (flooding, heat, sea-level rise, etc.) do they identify?',\n","    n_results=8\n",")\n","display_results(data)"]},{"cell_type":"markdown","id":"s9t0u1v2","metadata":{"id":"s9t0u1v2"},"source":["## 8. Interactive — Ask Your Own Question"]},{"cell_type":"code","execution_count":null,"id":"t0u1v2w3","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":8292,"status":"ok","timestamp":1772663776213,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"t0u1v2w3","outputId":"06c4e5a6-2713-4a75-d108-fa9984135032"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","Bank of America, JPMorgan Chase, and HSBC are heavily investing in sustainable finance initiatives to address climate change and facilitate a transition to a low-carbon economy. Each bank has set substantial financial targets to support environmentally focused projects by 2030.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: Sustainability_at_Bank_of_America_2024_Report.pdf\n","   SDGs:   SDG 7: Affordable and Clean Energy, SDG 9: Industry, Innovation and Infrastructure, SDG 11: Sustainable Cities and Communities, SDG 12: Responsible Consumption and Production, SDG 13: Climate Action, SDG 15: Life on Land\n","   Key Points:\n","     • Mobilizing and deploying $1.5 trillion in sustainable finance by 2030.\n","     • Focus on low-carbon fuels and sustainability-linked financing products.\n","     • Investing in nature-positive areas and sustainable supply chains.\n","\n","🏦 JPMorgan Chase  |  Risk Type: Both\n","   Source: jpmc-esg-report-2023.pdf\n","   SDGs:   SDG 7: Affordable and Clean Energy, SDG 11: Sustainable Cities and Communities, SDG 13: Climate Action, SDG 15: Life on Land\n","   Key Points:\n","     • Invested in the Sustainable Flight Fund for decarbonizing air travel.\n","     • Pledged $1 trillion to support climate solutions and resource management.\n","     • Financed $66 billion towards renewable and clean energy initiatives.\n","\n","🏦 HSBC  |  Risk Type: Transition Risk\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 7: Affordable and Clean Energy, SDG 9: Industry, Innovation and Infrastructure, SDG 11: Sustainable Cities and Communities, SDG 13: Climate Action\n","   Key Points:\n","     • Raised $1 billion through green bonds for renewable energy.\n","     • Launched HSBC Infrastructure Finance to support low-carbon projects.\n","     • Developed partnerships to scale clean energy projects in Southeast Asia.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","All three banks demonstrate a strong commitment to financing a global transition to sustainable energy, with Bank of America and JPMorgan Chase setting multi-trillion dollar sustainable finance targets. Bank of America focuses on integrating nature-positive investments, while JPMorgan Chase emphasizes a broad range of environmental projects. HSBC, on the other hand, is expanding its infrastructure finance capabilities to address specific regional needs in renewable energy, particularly in Asia.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 7: Affordable and Clean Energy, SDG 9: Industry, Innovation and Infrastructure, SDG 11: Sustainable Cities and Communities, SDG 12: Responsible Consumption and Production, SDG 13: Climate Action, SDG 15: Life on Land\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'What financing commitments have banks made toward green or sustainable projects?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"]},{"cell_type":"markdown","id":"7v0kPqXy6xK9","metadata":{"id":"7v0kPqXy6xK9"},"source":[]},{"cell_type":"markdown","id":"wZEY51QeDziU","metadata":{"id":"wZEY51QeDziU"},"source":["## Question 1: How does UBS define transition risk in its 2024 disclosures?"]},{"cell_type":"code","execution_count":null,"id":"vuSjguEJ6xeR","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":7963,"status":"ok","timestamp":1772666107694,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"vuSjguEJ6xeR","outputId":"4da5f4d5-0946-494f-84ed-6180495b039b"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","UBS focuses heavily on addressing climate-driven transition risks in its 2024 disclosures. It developed sophisticated models and frameworks like the Transition Risk Rating Model (TR RM) and Corporate Transition Assessment Scorecard (CTAS) to identify and manage these risks. UBS also emphasizes scenario-based approaches for assessing exposure to both transition and physical risks.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 UBS  |  Risk Type: Transition Risk\n","   Source: annual-report-ubs-group-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • UBS developed a Transition Risk Rating Model (TR RM) aligned with a Transition Risk Heatmap (TR H) for company-level transition risk assessment.\n","     • Exposure to climate-sensitive sectors was reduced due to the wind-down of Non-core and Legacy corporate exposures.\n","     • The integration of Credit Suisse systems led to data enhancements in risk metrics.\n","     • The firm focuses on integrating impacts and dependencies on a changing climate in risk management processes.\n","\n","🏦 UBS  |  Risk Type: Both\n","   Source: annual-report-ubs-group-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • UBS uses scenario-based approaches to assess exposure to both physical and transition risks.\n","     • The bank performed stress-testing exercises using industry collaborations and regulatory scenario analyses.\n","     • Internal capabilities for climate risk scenario analysis and stress testing were refined and expanded across 30 years.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","UBS demonstrates a detailed and structured approach to managing transition and physical risks through advanced modeling and scenario analysis techniques. It has also focused on integrating data from Credit Suisse to enhance its metrics. Unlike some banks that may be in the earlier stages of developing climate-related financial risk assessments, UBS's methods appear more mature, allowing it to anticipate and adjust to varied regulatory and environmental changes.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'How does UBS define transition risk in its 2024 disclosures?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"]},{"cell_type":"markdown","id":"Np6DbOUs6xeQ","metadata":{"id":"Np6DbOUs6xeQ"},"source":["## Question 2: Does HSBC quantify transition risk exposure in its most recent disclosures?"]},{"cell_type":"code","execution_count":null,"id":"jsXJqkb8D_9T","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":10875,"status":"ok","timestamp":1772500238123,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"jsXJqkb8D_9T","outputId":"77db298b-472a-48f9-dcc2-3a80cbaabc15"},"outputs":[{"name":"stdout","output_type":"stream","text":["======================================================================\n","SUMMARY\n","======================================================================\n","HSBC's recent climate risk disclosures highlight a comprehensive approach to assessing both transition and physical risks, though there are limitations in data availability affecting the depth of their reporting. HSBC is focused on understanding climate risks through scenario analysis and engaging with clients in high-risk sectors to facilitate net-zero transitions.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • HSBC conducts climate risk materiality assessments considering short-, medium-, and long-term time horizons.\n","     • The bank is facilitating between $750bn and $1tn of sustainable finance and investments by 2030.\n","     • 18% of the wholesale lending portfolio is exposed to six high transition risk sectors.\n","     • TEQ is used to assess business model alignment to net zero for wholesale customers.\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • HSBC uses scenarios to examine financial performance and capital resilience across potential climate outcomes.\n","     • Commitment to net zero transition includes updated scientific methodologies and climate-related policies.\n","     • Potential impairment impacts disclosed for wholesale and commercial real estate portfolios in different scenarios.\n","     • Flooding exposure disclosed in retail mortgage book for specific markets.\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Expanded TEQ allows global assessment of transition and physical risks of wholesale customers.\n","     • Predicted ECL in sectors under various climate scenarios.\n","     • Significant exposure to high transition risk sectors like chemicals and power and utilities.\n","     • Data limitations noted in full disclosure of climate risks.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","In contrast to several other G-SIBs that may focus more heavily on either transition or physical climate risks, HSBC takes a balanced approach by exploring both types. This includes detailed scenario analysis and targeted client engagement for high-risk transition sectors, although the same level of quantitative detail for physical risks is still developing. HSBC appears proactive in its TCFD reporting yet recognizes the limitations in data quality and scope, similar to its peers.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'Does HSBC quantify transition risk exposure in its most recent disclosures?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"]},{"cell_type":"markdown","id":"E3AsIoX2EJqv","metadata":{"id":"E3AsIoX2EJqv"},"source":["## Question 3: How do Citi and HSBC frame climate risk under SDG commitments?"]},{"cell_type":"code","execution_count":null,"id":"sdoq4EDHEMlR","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":5889,"status":"ok","timestamp":1772666154481,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"id":"sdoq4EDHEMlR","outputId":"129df83f-6969-423d-98d3-9a726a5b08f8"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","Both HSBC and Citi have framed their climate risk management strategies around comprehensive frameworks and scenarios, addressing both transition and physical risks while linking these efforts to specific SDGs. HSBC places a significant emphasis on managing reputational and regulatory risks associated with transition, whereas Citi focuses on sustainable finance products and operational net zero commitments.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action, SDG 17: Partnerships for the Goals\n","   Key Points:\n","     • Enhanced climate scenario analysis for power and utilities sector.\n","     • Development of guidelines for managing net zero alignment and greenwashing risks.\n","     • Governance structure that includes climate risk in risk management and strategic planning.\n","\n","🏦 Citigroup  |  Risk Type: Both\n","   Source: 2024-citi-climate-report.pdf\n","   SDGs:   SDG 7: Affordable and Clean Energy, SDG 13: Climate Action\n","   Key Points:\n","     • Commitment to achieving net zero GHG emissions by 2050.\n","     • Offering of sustainable finance products like green bonds and tax equity investing for renewables.\n","     • Integration of nature-related impacts and biodiversity into Environmental and Social Risk Management.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","HSBC leverages a multifaceted risk management structure aligning with its group-wide framework, emphasizing reputational risks such as greenwashing, while also addressing physical vulnerabilities with scenario analysis. In contrast, Citi emphasizes developing sustainable finance products and operational commitments to net zero, while embedding nature-related impacts within its environmental policy, reflecting differing tactical focuses in meeting SDG 13.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 7: Affordable and Clean Energy, SDG 13: Climate Action, SDG 17: Partnerships for the Goals\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'How do Citi and HSBC frame climate risk under SDG commitments?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"]},{"cell_type":"markdown","metadata":{"id":"0dJgN5HXO4z5"},"source":["## Question 4: What quantitative climate risk metrics does Bank of America disclose?\n"],"id":"0dJgN5HXO4z5"},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":6465,"status":"ok","timestamp":1772902880189,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"outputId":"74e7e04e-c73c-47d6-9024-17a605e39cb6","collapsed":true,"id":"_8Yes1GfOkLF"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","Bank of America discloses a variety of metrics related to both transition and physical climate risks. They assess climate-related risks in their commercial and consumer credit portfolios, market and liquidity risks, and compliance and operational risks through extensive frameworks and scenario analyses.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: Sustainability_at_Bank_of_America_2024_Report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Bank of America monitors market risks with daily reporting to identify climate-sensitive concentrations across sectors and geographies.\n","     • Stress tests are used to understand the impact of climate risks on trading portfolios.\n","     • Climate risk assessments help analyze liquidity risk caused by physical climate events.\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: SustainabilityatBofA2025_WCAG2.2_121625.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Bank of America uses physical risk modeling for geographic and portfolio-level monitoring.\n","     • They classify countries and industries based on vulnerability to climate risks from very low to very high.\n","     • Climate risk impacts are monitored at issuer and portfolio levels, stress tests help identify risk concentrations.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","Bank of America demonstrates a comprehensive approach to managing both transition and physical risks through detailed frameworks that incorporate climate considerations into their risk assessments and strategic decisions. While the bank undertakes stress testing and scenario analysis similar to peers in the industry, its adherence to sectoral classification of climate vulnerability and creation of a dedicated Climate Risk Framework are notable features that may differ in execution from other institutions.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'What quantitative climate risk metrics does Bank of America disclose?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"],"id":"_8Yes1GfOkLF"},{"cell_type":"markdown","metadata":{"id":"xFfv0BDCQ4TQ"},"source":["## Question 5: Which banks link climate disclosures to SDG 13?\n"],"id":"xFfv0BDCQ4TQ"},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":8280,"status":"ok","timestamp":1772903258366,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"outputId":"dfce2655-6135-4300-b3d1-3db330aa7d5c","collapsed":true,"id":"ByTufPb7Q6ao"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","Across the excerpts, all banks focus on sustainable finance initiatives and address climate-related risks. HSBC and Bank of America mention both physical and transition risks, whereas unknown banks focus more on partnerships and transition risks. Sustainable Development Goal 13: Climate Action is mentioned explicitly by Goldman Sachs but is implicitly linked through various activities outlined in the banks' reports.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • HSBC has mobilized $352.5bn of sustainable finance since January 2020.\n","     • Lack of full disclosure on climate-related opportunities and internal carbon pricing.\n","\n","🏦 Goldman Sachs  |  Risk Type: Transition Risk\n","   Source: accelerating-transition-report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Joined the Net Zero Banking Alliance and Open-Source Climate initiative.\n","     • Contribution to policy frameworks through Inevitable Policy Response.\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: Sustainability_at_Bank_of_America_2024_Report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Mobilized $560 billion towards sustainable finance goal, with a focus on the environmental transition.\n","     • Emphasis on SDG-aligned financing and policy advocacy.\n","\n","🏦 Bank of America  |  Risk Type: Transition Risk\n","   Source: SustainabilityatBofA2025_WCAG2.2_121625.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Engagement in policy to catalyze private investment for energy transitions.\n","     • Coordination with MDBs and DFIs for development in emerging markets.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","HSBC and Bank of America discuss both physical and transition risks in their disclosures, suggesting a comprehensive approach to climate-related challenges. In contrast, Goldman Sachs mainly focuses on facilitating transition risks through collaboration, policy influence, and technology development. All banks mention their roles in mobilizing significant amounts of sustainable finance, but their methods and areas of focus—such as policy advocacy, partnership establishments, or direct financing—differ.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'Which banks link climate disclosures to SDG 13?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"],"id":"ByTufPb7Q6ao"},{"cell_type":"markdown","metadata":{"id":"ep5wmb87RqAu"},"source":["## Question 6: How does Citi describe transition risks from regulatory changes?\n","\n"],"id":"ep5wmb87RqAu"},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":3799,"status":"ok","timestamp":1772903538422,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"outputId":"18fbf4e0-5b5a-4e54-b219-471c1c36f217","collapsed":true,"id":"ftI-jWs3RqAw"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","The excerpts focus on banks' disclosures regarding transition and physical risks related to climate change, with attention to regulatory changes impacting Citi.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 Citi  |  Risk Type: Transition Risk\n","   Source: unknown\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Transition risks at Citi include exposure to regulatory changes.\n","     • Potential impacts of carbon pricing and policy shifts are considered significant.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","Citi explicitly addresses transition risks primarily stemming from regulatory changes, carbon pricing, and policy shifts, while other banks may emphasize different aspects such as technology shifts or legal risks.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'How does Citi describe transition risks from regulatory changes?'\n","my_bank     = 'Citi'    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"],"id":"ftI-jWs3RqAw"},{"cell_type":"markdown","metadata":{"id":"Pz567vzJRtYq"},"source":["## Question 7: Which banks mention physical risks related to extreme weather events?\n","\n"],"id":"Pz567vzJRtYq"},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":11030,"status":"ok","timestamp":1772903709537,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"outputId":"6bc43f96-93c6-4cf4-942c-f5055880afab","collapsed":true,"id":"XL9KqymQRtYr"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","The disclosures from Bank of America, JPMorgan Chase, and UBS highlight their comprehensive approaches to managing climate risks, focusing on both physical and transition risks. They each provide detailed strategies and risk assessments concerning various climate-related impacts, emphasizing SDG 13: Climate Action as a common goal.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: Sustainability_at_Bank_of_America_2024_Report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Granular risk categorization including acute physical risks like extreme heat and transition risks like stranded assets.\n","     • Risk management spans across various economic impacts, including credit, market, and compliance risks related to climate events.\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: SustainabilityatBofA2025_WCAG2.2_121625.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Focus on consumer credit risk impacted by physical risks like natural disasters and transition risks such as policy and market changes.\n","     • Insurance oversight and physical risk modeling are key measures for managing climate-related risks in credit portfolios.\n","\n","🏦 JPMorgan Chase  |  Risk Type: Both\n","   Source: jpmc-sustainability-report-2024 copy.pdf\n","   SDGs:   SDG 7: Affordable and Clean Energy, SDG 8: Decent Work and Economic Growth, SDG 13: Climate Action\n","   Key Points:\n","     • Physical climate risks are mitigated through geographic diversification and insurance but future limitations are acknowledged.\n","     • Strategic risks arise from both physical damages and transition to low-carbon economy impacting consumer preferences and market conditions.\n","\n","🏦 UBS  |  Risk Type: Physical Risk\n","   Source: annual-report-ubs-group-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Development of physical risk rating models to assess acute hazards like floods and wildfires.\n","     • Reduction in climate-sensitive physical risk exposure through strategic adjustments in regions with high adaptive capacity.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","All banks recognize the seriousness of climate risks, but they differ in their approaches. Bank of America focuses on detailed risk management across credit, market, and compliance spheres, while JPMorgan Chase underscores the adaptation of existing models to include both physical and transition risks. UBS has taken steps to create specific models for assessing physical risks, showing a strong emphasis on technical risk evaluation and reduction of sensitive exposure.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 7: Affordable and Clean Energy, SDG 8: Decent Work and Economic Growth, SDG 13: Climate Action\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'which banks mention physical risks related to extreme weather events?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"],"id":"XL9KqymQRtYr"},{"cell_type":"markdown","metadata":{"id":"v175Tsa-TbZM"},"source":["## Question 8: Which banks discuss scenario analysis for climate transition risk?"],"id":"v175Tsa-TbZM"},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":6606,"status":"ok","timestamp":1772903872045,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"outputId":"388a359e-dcd1-43b6-88da-d8b997ebe9b0","collapsed":true,"id":"Gvtczt6uTbZN"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","Across the presented disclosures, all banks showcase robust efforts in employing climate scenario analyses to understand and mitigate risks linked to physical and transition forces of climate change. Their approaches cover various time horizons with a focus on refining methodologies and increasing portfolio coverage for transitioning to a net zero economy.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 Citigroup  |  Risk Type: Both\n","   Source: 2024-citi-climate-report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Conducted internal and regulatory climate risk scenario analyses across physical and transition scenarios.\n","     • Completed combined transition and physical risk scenario analysis for wholesale and real estate portfolios.\n","\n","🏦 UBS  |  Risk Type: Both\n","   Source: annual-report-ubs-group-2024.pdf\n","   SDGs:   SDG 13: Climate Action, SDG 17: Partnerships for the Goals\n","   Key Points:\n","     • Focused on transition and physical risk projections across 30 years.\n","     • Developed additional climate risk methodologies to enhance portfolio coverage.\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Produced several climate stress tests for global regulators.\n","     • Scenario analysis supports internal capital adequacy and strategic planning.\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: Sustainability_at_Bank_of_America_2024_Report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Explores transition and physical risk events using a dynamic balance sheet.\n","     • Uses NGFS and IPCC scenarios as backdrops for climate scenario analysis.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","All banks employ comprehensive climate scenario analyses, integrating both transition and physical risks into their assessment frameworks. However, UBS and HSBC appear to have a stronger emphasis on international industry collaborations to refine their methodologies, whereas Citigroup and Bank of America leverage internal models alongside regulatory frameworks. HSBC and Bank of America show a pronounced focus on utilizing scenario outputs to refine strategic planning and risk management at both portfolio and enterprise levels.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action, SDG 17: Partnerships for the Goals\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'Which banks discuss scenario analysis for climate transition risk?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"],"id":"Gvtczt6uTbZN"},{"cell_type":"markdown","metadata":{"id":"sGcf3u7VVbzD"},"source":["## Question 9: What risks are associated with stranded assets?\n"],"id":"sGcf3u7VVbzD"},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":10687,"status":"ok","timestamp":1772904413466,"user":{"displayName":"Fangyuan Lu","userId":"11221447903849902118"},"user_tz":300},"outputId":"aab5540f-a52e-45d3-c70f-e179c1aecdf4","collapsed":true,"id":"neUEofxeVbzE"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","SUMMARY\n","======================================================================\n","The excerpts highlight how major banks are addressing climate risks and their implications on financial performance and strategic planning. JPMorgan Chase, HSBC, and Bank of America emphasize both physical and transition risks, identifying numerous challenges and opportunities linked to climate change. These include regulatory changes, consumer preferences, technological advancement, and physical climate events impacting asset valuations and operational resilience.\n","\n","======================================================================\n","FINDINGS BY BANK\n","======================================================================\n","\n","🏦 JPMorgan Chase  |  Risk Type: Transition Risk\n","   Source: J.P. Morgan Asset Management 2025 Global Climate Report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Companies with high emissions face decreased profits and potential litigation.\n","     • Stranded asset risk is significant for sectors like Oil, Gas, Utilities, Energy, and Materials.\n","\n","🏦 HSBC  |  Risk Type: Both\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Projected flood risks have the largest impact potential on the portfolio.\n","     • Regulatory compliance risk from increasing climate-related expectations.\n","\n","🏦 HSBC  |  Risk Type: Transition Risk\n","   Source: 250219-annual-report-and-accounts-2024.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Reputational risk linked to support for high-emitting sectors transitioning to net zero.\n","     • Potential legal and regulatory risks from ESG-related targets and stakeholder actions.\n","\n","🏦 Bank of America  |  Risk Type: Both\n","   Source: SustainabilityatBofA2025_WCAG2.2_121625.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Physical climate events impact repayment capacity and asset valuations.\n","     • Market risks due to changing regulations and shifting to climate-related investments.\n","\n","🏦 JPMorgan Chase  |  Risk Type: Both\n","   Source: jpmc-sustainability-report-2024 copy.pdf\n","   SDGs:   SDG 13: Climate Action, SDG 11: Sustainable Cities and Communities\n","   Key Points:\n","     • Increased operational and legal risks from severe weather events.\n","     • Impact on earnings and reputation from a lack of green business opportunities.\n","\n","🏦 JPMorgan Chase  |  Risk Type: Both\n","   Source: J.P. Morgan Asset Management 2025 Global Climate Report.pdf\n","   SDGs:   SDG 13: Climate Action\n","   Key Points:\n","     • Extreme weather events affecting asset valuation in real estate and infrastructure.\n","     • Transition opportunities and risks within legislative and regulatory environments.\n","\n","======================================================================\n","CROSS-FIRM COMPARISON\n","======================================================================\n","JPMorgan Chase and HSBC demonstrate a comprehensive approach to both transition and physical risks by integrating climate considerations into asset management and lending strategies. HSBC focuses extensively on regulatory compliance and reputational risks, reflecting its global operations across varied jurisdictions. Bank of America addresses the impact of physical events and policy changes on market conditions and asset values. Although all banks emphasize transition trends, JPMorgan stands out in leveraging market opportunities associated with low-carbon technologies.\n","\n","======================================================================\n","ALL SDGs IDENTIFIED ACROSS BANKS\n","======================================================================\n","SDG 13: Climate Action, SDG 11: Sustainable Cities and Communities\n","======================================================================\n"]}],"source":["# Interactive — change the question and bank_filter as needed\n","# Available banks: 'JPMorgan Chase', 'Citigroup', 'HSBC', 'UBS', 'Goldman Sachs', 'Bank of America'\n","\n","my_question = 'What risks are associated with stranded assets?'\n","my_bank     = None    # or e.g. 'HSBC'\n","\n","data = query_rag(my_question, n_results=6, bank_filter=my_bank)\n","display_results(data)"],"id":"neUEofxeVbzE"},{"cell_